# ─── OS & Editor Artifacts ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Microsoft Office Temp Files ────────────────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp

# ─── Draw.io Backup Files ────────────────────────────────────────────────────
*.drawio.bak

# ─── Python (if any scripts used) ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.env
.venv/
venv/

# ─── Node / JS (if any tooling) ─────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── Sensitive / Proprietary ─────────────────────────────────────────────────
# Real-world project files that should NOT be committed
04_Projects/Real-World-Projects/**/*.docx
04_Projects/Real-World-Projects/**/*.xlsx
04_Projects/Real-World-Projects/**/*.pdf
# Override: allow templates and READMEs in real-world projects
!04_Projects/Real-World-Projects/**/*-TEMPLATE*
!04_Projects/Real-World-Projects/**/README.md

# ─── Large Binary Files ──────────────────────────────────────────────────────
*.mdzip
*.mdzip.bak

# ─── Reference Books (local only — do NOT push to GitHub) ────────────────────
# These are large copyrighted PDFs/EPUBs stored locally for study reference.
# Each team member should obtain their own licensed copies.
05_Resources/Books-and-References/*.pdf
05_Resources/Books-and-References/*.epub
05_Resources/Books-and-References/*.PDF

# ─── IDE / Tool Configs ──────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
